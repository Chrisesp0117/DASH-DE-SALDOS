{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "functions": {
    "api/**/*.js": {
      "runtime": "nodejs20.x",
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/bootstrap-webhook",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/update",
      "schedule": "0 */2 * * *"
    },
    {
      "path": "/api/cron/report-8h",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/cron/report-17h",
      "schedule": "0 20 * * *"
    }
  ]
}
