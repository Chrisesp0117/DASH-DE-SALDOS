# Google Ads Configuration
CLIENT_ID=your-google-client-id.apps.googleusercontent.com
CLIENT_SECRET=your-google-client-secret
REFRESH_TOKEN=your-google-refresh-token
DEVELOPER_TOKEN=your-google-developer-token

# Meta Configuration
META_TOKEN=your-meta-access-token

# Google Sheets Configuration
SPREADSHEET_ID=your-spreadsheet-id

# Supabase (banco de dados — DATABASE + JOB_STATE + JOB_QUEUE)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=eyJhbGc...
# SUPABASE_DATABASE_TABLE=database_rows  # opcional, padrão: database_rows
# SUPABASE_JOB_QUEUE_TABLE=job_queue        # opcional, padrão: job_queue
# JOB_QUEUE_STALE_SECONDS=300               # opcional, default 5min para re-enfileirar running stale

# Cron security
CRON_SECRET=your-cron-secret

# Job execution tuning (optional - uses sensible defaults if not set)
# UPDATE_BATCH_SIZE=50           # Clients per batch (default: 50)
# UPDATE_MAX_ITERATIONS=10       # Max iterations per invocation (default: 10)
# CRON_MAX_RUNTIME_MS=150000     # Max runtime for cron (default: 150000 = 150s, must be < Vercel maxDuration)
# HEARTBEAT_INTERVAL_MS=20000    # Heartbeat interval (default: 20000 = 20s)
# HEARTBEAT_MISSED_COUNT=3       # Stale threshold (default: 3 missed heartbeats)

# Google Ads MCCs
MCC_ID=your-primary-mcc-id
MCC_FALLBACK_1=your-fallback-mcc-1
MCC_FALLBACK_2=your-fallback-mcc-2

# Notes:
# - CLIENT_ID, CLIENT_SECRET, REFRESH_TOKEN: obtain from Google Cloud Console
# - DEVELOPER_TOKEN: obtain from Google Ads Manager Account
# - META_TOKEN: long-lived access token from Meta App (Business Suite or Marketing API)
# - SPREADSHEET_ID: ID from the URL of your Google Sheet
# Telegram integration removed: no Telegram environment variables required
# - CRON_SECRET: shared secret used by Apps Script (e outros callers) para chamar os endpoints de cron/worker
# 
# Setup Instructions:
# 1. Copy this file to .env
# 2. Fill in the values from your Google and Meta accounts
# 3. Do NOT commit .env to version control (already in .gitignore)
# 4. Ensure META_TOKEN has permissions for the Meta ad accounts in your Clientes sheet
# 5. Ensure REFRESH_TOKEN has access to the Google Ads customers via the MCC_ID
# 6. Rode o SQL em supabase_schema.sql no Supabase antes do deploy
